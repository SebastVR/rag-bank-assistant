


########################################
# DESARROLLO LOCAL (MinIO, Postgres, Qdrant, Redis, RabbitMQ, Flower)
########################################
APP_NAME=rag-bank-assistant
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# MinIO (local/desarrollo)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=rag-bank-assistant-data

# Postgres (desarrollo)
POSTGRES_DB=rag-bank-assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Qdrant (vector store)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION_NAME=rag-bank-assistant
QDRANT_MAX_CHUNKS_RETRIEVED=10
QDRANT_MAX_CHUNKS_RERANKED=3

# RAG (chunking/embeddings/reranker)
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150
RAG_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# LLM runtime
LLM_PROVIDER=llama_cpp
LLM_MODEL_NAME=Qwen3-VL-4B-Instruct-Q4_K_M.gguf
LLM_MODEL_PATH=app/rag/Qwen3-VL-4B-Instruct-Q4_K_M.gguf
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=


# Redis (broker/cache para Celery)
REDIS_HOST=redis
REDIS_PORT=6379

# RabbitMQ (broker para Celery)
CELERY_BROKER_URL=amqp://ra881Tu5er:ra881Tpa55@rabbitmq:5672// # Nombre del servicio Redis en docker-compose
CELERY_BACKEND_URL=redis://redis:6379/1 # Nombre del servicio Redis en docker-compose

RABBITMQ_DEFAULT_USER=ra881Tu5er
RABBITMQ_DEFAULT_PASS=ra881Tpa55



# Scraping
SCRAPER_BASE_URL=https://www.bbva.com.co/
SCRAPER_ALLOWED_DOMAIN=bbva.com.co
SCRAPER_MAX_PAGES=10
SCRAPER_TIMEOUT=20
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

RAW_DATA_PATH=data/raw
PROCESSED_DATA_PATH=data/processed

########################################
# PRODUCCIÓN (Supabase, AWS S3)
########################################
# AWS S3 (producción)
AWS_REGION_NAME=us-east-1
AWS_S3_ACCESS_KEY_ID=your_aws_access_key
AWS_S3_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET_NAME=rag-bank-assistant-data

# Supabase (producción)
SUPABASE_URL=https://dcymlylndtnzzgbxfnbd.supabase.co
SUPABASE_SERVICE_KEY=sb_publishable_T0vOVg1q_SkORmI3cXUstg_5j-Z-8B_
SUPABASE_ATTACHMENT_BUCKET=rag-bank-assistant
